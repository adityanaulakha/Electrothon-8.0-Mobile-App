{
  "expo": {
    "name": "Trynex",
    "slug": "trynex-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow Trynex to access your photos for look generation.",
        "NSCameraUsageDescription": "Allow Trynex to use camera for taking your photo."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Trynex to access your photos for look generation.",
          "cameraPermission": "Allow Trynex to use camera for taking your photo."
        }
      ],
      "expo-sharing"
    ],
    "extra": {
      "eas": {
        "projectId": "3711e103-ce69-48af-80c8-8ac866cdaf28"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3711e103-ce69-48af-80c8-8ac866cdaf28"
    }
  }
}
